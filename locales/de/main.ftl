# German locale

welcome =
    👋 Hallo { $name }!
    Ich bin dein Musik-Begleiter — suche Tracks, hole Songtexte,
    remixe mit Effekten und entdecke ähnliche Songs.

    Tippe unten ein Beispiel oder schick mir einfach einen Songnamen 🎵
help =
    🎵 <b>So funktioniert's</b>

    • Sende einen Song-/Künstlernamen zum Suchen
    • Tippe ein Ergebnis an, um den Track zu erhalten
    • 🎛️ Remix für Nightcore, Slowed, 8D und mehr
    • 🎤 Songtext für Text + Übersetzung
    • Inline: tippe <code>@bot suche</code> in jedem Chat

    /settings — Sprache ändern
language-set = ✅ Sprache auf Deutsch gestellt
settings-language = 🌍 Wähle deine Sprache:

searching = 🔎 Suche…
delivering = 📥 Track wird geladen…
loading = ⏳ Lädt…
translating = 🌐 Übersetze…
processing = ⏳ Remix wird erstellt…
processing-heavy = ⏳ Verarbeitung (aufwändig, ~15 Sek.)…

results-header = 🔎 Ergebnisse für „{ $query }“ — { $count } gefunden
no-results = 😔 Nichts gefunden für „{ $query }“. Andere Schreibweise?
results-expired = ⌛ Ergebnisse abgelaufen. Bitte erneut suchen.
nothing-found = 😔 Nichts gefunden.

nav-prev = Zurück
nav-next = Weiter

error-generic = ⚠️ Etwas ging schief. Bitte erneut versuchen.
flood-wait = ⏳ Immer langsam, bitte einen Moment.
track-unavailable = ⚠️ Dieser Track ist nicht mehr verfügbar.
no-audio-source =
    ⚠️ Kein abspielbares Audio für diesen Track.
    Richte eine lizenzierte Quelle ein, sonst nur Vorschauen.
preview-notice = 30-Sekunden-Vorschau
flac-unavailable = ⭐ Voll-/FLAC-Download braucht eine lizenzierte Quelle.
quality-unknown = unbekannt
quality-info = 📊 Beste verfügbare: { $bitrate }

liked = ❤️ Zu Favoriten hinzugefügt
unliked = 💔 Aus Favoriten entfernt
added-playlist = ➕ Zur Playlist hinzugefügt

similar-header = 🎵 Ähnlich wie { $track }
artist-header = 👤 Top-Tracks von { $artist }
album-header = 💿 { $album }
share-text = 📤 Schau dir { $track } an: { $link }
remix-choose = 🎛️ Wähle einen Effekt:

lyrics-not-found = 🤷 Kein Songtext gefunden.
translate-failed = ⚠️ Übersetzung gerade nicht möglich.

