flood-wait = ⏳ Повільніше, будь ласка.
track-unavailable = ⚠️ Цей трек більше недоступний.
no-audio-source =
    ⚠️ Немає аудіо для цього треку.
    Налаштуй ліцензоване джерело або доступні лише превʼю.
preview-notice = превʼю 30 секунд
flac-unavailable = ⭐ Повне завантаження/FLAC потребує ліцензованого джерела.
quality-unknown = невідомо
